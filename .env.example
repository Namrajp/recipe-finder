# OpenAI API Key - Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Polar billing — required for /api/checkout and Pro status (Organization → Products, Settings → API)
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
# Use sandbox while testing: POLAR_SERVER=sandbox
# POLAR_SERVER=production

# Public URL for checkout success/return redirects (optional locally; inferred from request Host if unset)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: shareable checkout link from Polar if you skip API-created sessions
# POLAR_CHECKOUT_URL=

# Vercel Blob (legacy; this app stores images in Supabase Storage)
# BLOB_READ_WRITE_TOKEN=
