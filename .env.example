# OpenAI API Key - Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Polar billing — pick ONE approach for checkout:
# (A) POLAR_CHECKOUT_URL — paste Polar’s share/checkout link (no API keys for checkout).
# (B) POLAR_ACCESS_TOKEN + POLAR_PRODUCT_ID — programmatic checkout from the app.
# In-app Pro status (unlimited searches, recipe images) uses Polar’s API: set POLAR_ACCESS_TOKEN
# (same org as checkout). POLAR_PRODUCT_ID is optional; if unset, any active/trialing subscription counts as Pro.
# After payment, Polar can redirect to /success, /checkout/success, or /?checkout=success — all work.
POLAR_CHECKOUT_URL=
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
# FREE_SEARCH_LIMIT=3   # optional; non‑Pro recipe generations (not cache hits) per user before quota
# POLAR_SERVER=sandbox   # when using API against Polar sandbox

# Canonical public URL (no trailing slash). On Vercel, set this (or rely on VERCEL_URL) for production.
# Locally: if you open http://localhost:3000, magic links and callbacks use localhost even when this
# is set to your production URL—so you can keep one .env for both. Supabase must allow
# http://localhost:3000/auth/callback for local testing.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Vercel Blob (legacy; this app stores images in Supabase Storage)
# BLOB_READ_WRITE_TOKEN=
