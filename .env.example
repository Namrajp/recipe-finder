# OpenAI API Key - Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Polar billing — required for /api/checkout and Pro status (Organization → Products, Settings → API)
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
# Use sandbox while testing: POLAR_SERVER=sandbox
# POLAR_SERVER=production

# Canonical public URL (no trailing slash). On Vercel, VERCEL_URL is also baked into the client as
# NEXT_PUBLIC_VERCEL_URL so magic links default to https://YOUR-PROJECT.vercel.app without this—set
# NEXT_PUBLIC_APP_URL when using a custom domain. Supabase → Authentication → URL Configuration must
# list Site URL and https://YOUR_HOST/auth/callback in Redirect URLs.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Optional: shareable checkout link from Polar if you skip API-created sessions
# POLAR_CHECKOUT_URL=

# Vercel Blob (legacy; this app stores images in Supabase Storage)
# BLOB_READ_WRITE_TOKEN=
